# Application Settings
APP_NAME=Castor
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Database Settings
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=castor
DATABASE_USER=castor
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_SSL=false

# Security Settings
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_ALGORITHM=HS512
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=castor-auth-api
JWT_AUDIENCE=castor-services

# Encryption Settings
ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_KEY_BASE64
ENCRYPTION_SALT=CHANGE_ME_GENERATE_16_BYTE_SALT_BASE64

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HASH_ROUNDS=12

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_BURST=10
LOGIN_RATE_LIMIT_PER_MINUTE=5
REGISTRATION_RATE_LIMIT_PER_HOUR=10

# CORS Settings
CORS_ORIGINS=["https://your-frontend-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH"]
CORS_ALLOW_HEADERS=["*"]

# Session Settings
SESSION_COOKIE_NAME=castor_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
SESSION_MAX_AGE=3600

# MFA Settings
MFA_ISSUER=VRIP7
MFA_ENABLED=true
MFA_ENFORCEMENT=optional

# API Key Settings
API_KEY_LENGTH=64
API_KEY_PREFIX=cstr_
API_KEY_HASH_ALGORITHM=sha512

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/castor/auth.log
AUDIT_LOG_FILE_PATH=/var/log/castor/audit.log
SECURITY_LOG_FILE_PATH=/var/log/castor/security.log

# Security Headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
CONTENT_SECURITY_POLICY=default-src 'self'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
REFERRER_POLICY=strict-origin-when-cross-origin

# TLS/SSL Settings
SSL_CERT_FILE=/etc/ssl/certs/server.crt
SSL_KEY_FILE=/etc/ssl/private/server.key
SSL_VERIFY=true
MIN_TLS_VERSION=TLSv1.3

# Account Security
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
PASSWORD_EXPIRY_DAYS=90
SESSION_CONCURRENT_LIMIT=5

# Audit Settings
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=365

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
